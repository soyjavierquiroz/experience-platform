APP_URL=http://mnle.localhost:3000
DEFAULT_TENANT_SLUG=mnle
TENANT_RESOLUTION_MODE=hostname
DATABASE_URL=postgresql://experience_app:change-me@postgres:5432/experience_platform
BETTER_AUTH_SECRET=generate-at-least-32-random-characters
BETA_AUTO_ENROLL=true
AUTH_SECURE_COOKIES=false
EMAIL_ENABLED=false
EMAIL_PROVIDER=disabled
AUTH_EMAIL_OTP_ENABLED=false
AWS_REGION=
SES_FROM_EMAIL=acceso@sayk.us
SES_REPLY_TO_EMAIL=soporte@sayk.us
AWS_ACCESS_KEY_ID_FILE=
AWS_SECRET_ACCESS_KEY_FILE=
# Production uses *_FILE paths mounted from Docker Secrets. Never commit real values.
